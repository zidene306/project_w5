##############################################################################
# Function: get completion duration for every client
##############################################################################
def get_all_step_duration(df):
    """
    Input: the cleaned df
    calculatrs for every user the whole duration of all the steps
    output: df: client_id, end_time, start_time, all steps duration in hours and days/H/M/S
    """
    
    df1 = df.copy()
    df1 = df1.sort_values(['client_id', 'date_time'], ascending = True)
    df1 = df1.groupby('client_id')['date_time'].agg(["max", "min"]).reset_index()
    df1["all_step_duration"] = df1["max"] - df1["min"]
    #cast to hours
    df1["all_step_dur_hr"] = round(df1['all_step_duration'].dt.total_seconds()/3600, 3)
    #rename columns:
    df1 = df1.rename(columns = {'max': 'end_time', 'min' : 'start_time'})
    #rearrange columns
    df1 = df1.loc[:, ['start_time', 'end_time', 'all_step_duration', 'all_step_dur_hr']]
    return df1


